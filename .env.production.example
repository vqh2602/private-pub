# Copy to .env.production, replace every CHANGE_ME value, then run:
# docker compose --env-file .env.production up --build -d
ENV_FILE=.env.production

NODE_ENV=production
APP_VERSION=0.1.0
FVM_VERSION=3.2.1
FLUTTER_VERSION=3.41.9
FVM_EXECUTABLE=fvm

# Public endpoints. Use HTTPS in production.
NEXT_PUBLIC_API_URL=https://api.registry.example.com
PUBLIC_BASE_URL=https://api.registry.example.com
CORS_ORIGINS=https://registry.example.com
TRUST_PROXY=loopback
COOKIE_SECURE=true

# Replace with high-entropy values. DATABASE_URL must contain a URL-encoded
# password if the password has reserved URL characters.
POSTGRES_USER=private_pub
POSTGRES_PASSWORD=CHANGE_ME_USE_A_LONG_RANDOM_DATABASE_PASSWORD
POSTGRES_DB=private_pub
DOCKER_DATABASE_URL=postgresql://private_pub:CHANGE_ME_USE_A_LONG_RANDOM_DATABASE_PASSWORD@postgres:5432/private_pub?schema=public
REDIS_URL=redis://redis:6379
TOKEN_PEPPER=CHANGE_ME_WITH_AT_LEAST_32_RANDOM_CHARACTERS
DEFAULT_ADMIN_USERNAME=registry-admin
DEFAULT_ADMIN_PASSWORD=CHANGE_ME_WITH_A_LONG_RANDOM_ADMIN_PASSWORD
SESSION_TTL_HOURS=12

DEMO_MODE=false
PUBLISHER_ID=platform.internal
ARCHIVE_STORAGE_DIR=/data/archives

# Keep mock analysis until the worker is hardened as an isolated sandbox.
MOCK_ANALYZER=true
ANALYZER_SANDBOXED=false
MAX_ARCHIVE_BYTES=104857600
MAX_UNCOMPRESSED_BYTES=268435456
MAX_ARCHIVE_FILES=65536
MAX_TEXT_PREVIEW_BYTES=512000
UPLOAD_SESSION_TTL_MS=900000
MAX_PENDING_UPLOAD_SESSIONS=20
MAX_PENDING_UPLOAD_SESSIONS_PER_ACTOR=3
MAX_SCORE_BACKFILLS_PER_STARTUP=100
