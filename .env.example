# Local development configuration. Copy to .env before running `npm run dev`.
NODE_ENV=development
APP_VERSION=0.1.0
FVM_VERSION=3.2.1
FLUTTER_VERSION=3.41.9
FVM_EXECUTABLE=fvm
API_PORT=4000

# Local endpoints. HTTP cookies are acceptable only for local development.
NEXT_PUBLIC_API_URL=http://localhost:4000
PUBLIC_BASE_URL=http://localhost:4000
TRUST_PROXY=loopback
CORS_ORIGINS=http://localhost:3000
COOKIE_SECURE=false

# Local Docker and direct-development database connections.
POSTGRES_USER=private_pub
POSTGRES_PASSWORD=private_pub
POSTGRES_DB=private_pub
DOCKER_DATABASE_URL=postgresql://private_pub:private_pub@postgres:5432/private_pub?schema=public
DATABASE_URL=postgresql://private_pub:private_pub@localhost:5432/private_pub?schema=public
REDIS_URL=redis://localhost:6379

# Local-only credentials. Production must replace these values with secrets.
TOKEN_PEPPER=replace-me-with-a-long-random-value
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin
SESSION_TTL_HOURS=12

# Registry storage and analysis.
DEMO_MODE=false
PUBLISHER_ID=platform.internal
DEMO_STORAGE_DIR=.private-pub-data/archives
ARCHIVE_STORAGE_DIR=.private-pub-data/archives
MOCK_ANALYZER=true
ANALYZER_SANDBOXED=false
MAX_ARCHIVE_BYTES=104857600
MAX_UNCOMPRESSED_BYTES=268435456
MAX_ARCHIVE_FILES=65536
MAX_TEXT_PREVIEW_BYTES=512000
UPLOAD_SESSION_TTL_MS=900000
MAX_PENDING_UPLOAD_SESSIONS=20
MAX_PENDING_UPLOAD_SESSIONS_PER_ACTOR=3
MAX_SCORE_BACKFILLS_PER_STARTUP=100
